rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // プロフィール画像: ログインユーザーは全員読み取り可（フレンド一覧などで表示）、書き込みは本人のみ
    match /users/{uid}/avatar/{allPaths=**} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == uid;
    }
  }
}
